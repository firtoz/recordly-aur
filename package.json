{
	"name": "recordly-aur",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.10",
	"engines": {
		"bun": ">=1.1.0"
	},
	"scripts": {
		"update-aur": "bun run update-aur.ts",
		"update-aur:dry": "DRY_RUN=1 bun run update-aur.ts",
		"update-aur:force": "FORCE=1 bun run update-aur.ts",
		"update-aur:dry:force": "DRY_RUN=1 FORCE=1 bun run update-aur.ts",
		"verify-packaging": "bun run update-aur.ts --verify-only",
		"audit-upstream": "bun run audit-upstream.ts",
		"check-aur-vs-latest": "bun run check-aur-vs-latest.ts",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"bun-types": "^1.3.11",
		"typescript": "^5.9.3"
	}
}
